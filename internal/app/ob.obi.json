  "version": "0.1.0",
  "schemas": {
    "ContextEntry": {
      "type": "object",
      "description": "A stored context entry.",
      "properties": {
        "key": {
          "type": "string",
          "description": "Context store key (typically a normalized API origin)."
        },
        "context": {
          "type": "object",
          "description": "Opaque credential map. Well-known fields include 'bearerToken', 'apiKey', 'basic'.",
          "additionalProperties": true
        }
      },
      "required": [
        "key"
      ],
      "additionalProperties": false
    },
    "CreateInterfaceSource": {
      "type": "object",
      "description": "A binding source to extract operations from.",
      "properties": {
        "format": {
          "type": "string",
          "description": "Format token (e.g., openapi@3.1, usage@2.13.1)."
        },
        "name": {
          "type": "string",
          "description": "Key name for this binding source in the output OBI's sources."
        },
        "location": {
          "type": "string",
          "description": "Location to fetch content from (path or URL)."
        },
        "content": {
          "description": "Content provided directly."
        },
        "outputLocation": {
          "type": "string",
          "description": "Location to reference in the output OBI's binding source."
        },
        "embed": {
          "type": "boolean",
          "description": "If true, embed content inline in the output OBI."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description for this binding source."
        }
      },
      "required": [
        "format"
      ],
      "oneOf": [
        {
          "required": [
            "location"
          ]
        },
        {
          "required": [
            "content"
          ]
        }
      ],
      "additionalProperties": false
    },
    "CreateInterfaceInput": {
      "type": "object",
      "properties": {
        "openbindingsVersion": {
          "type": "string",
          "description": "Target OpenBindings spec version (e.g., '0.1.0')."
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/schemas/CreateInterfaceSource"
          },
          "description": "Binding sources to extract from."
        },
        "name": {
          "type": "string",
          "description": "Interface name override."
        },
        "version": {
          "type": "string",
          "description": "Interface contract version override."
        },
        "description": {
          "type": "string",
          "description": "Interface description override."
        }
      },
      "additionalProperties": false
    },
    "OpenBindingsInterface": {
      "type": "object",
      "description": "A valid OpenBindings interface document.",
      "additionalProperties": true
    },
    "ExecuteSource": {
      "type": "object",
      "description": "Binding source for execution.",
      "properties": {
        "format": {
          "type": "string",
          "description": "Format token (e.g., openapi@3.1)."
        },
        "location": {
          "type": "string",
          "description": "Location of the binding source."
        },
        "content": {
          "description": "Binding source content directly."
        }
      },
      "required": [
        "format"
      ],
      "oneOf": [
        {
          "required": [
            "location"
          ]
        },
        {
          "required": [
            "content"
          ]
        }
      ],
      "additionalProperties": false
    },
    "BindingContext": {
      "type": "object",
      "description": "Opaque runtime context for binding execution.",
      "additionalProperties": true
    },
    "ExecutionOptions": {
      "type": "object",
      "description": "Developer-supplied per-request execution options.",
      "properties": {
        "headers": {
          "type": "object",
          "description": "HTTP headers.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "cookies": {
          "type": "object",
          "description": "Cookies.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "environment": {
          "type": "object",
          "description": "Environment variables.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "description": "Open metadata map.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ExecuteBindingInput": {
      "type": "object",
      "description": "Input for executing a resolved binding.",
      "properties": {
        "source": {
          "$ref": "#/schemas/ExecuteSource",
          "description": "The binding source."
        },
        "ref": {
          "type": "string",
          "description": "Reference within the binding source."
        },
        "input": {
          "description": "Operation input data."
        },
        "context": {
          "$ref": "#/schemas/BindingContext",
          "description": "Runtime binding context."
        },
        "options": {
          "$ref": "#/schemas/ExecutionOptions",
          "description": "Developer-supplied execution options."
        }
      },
      "required": [
        "source",
        "ref"
      ],
      "additionalProperties": false
    },
    "Error": {
      "type": "object",
      "description": "Structured error information.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code."
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message."
        },
        "details": {
          "description": "Additional error details."
        }
      },
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "ExecuteBindingOutput": {
      "type": "object",
      "description": "Output from executing a resolved binding.",
      "properties": {
        "output": {
          "description": "Operation output data."
        },
        "status": {
          "type": "integer",
          "description": "Status or exit code."
        },
        "durationMs": {
          "type": "number",
          "description": "Execution duration in milliseconds."
        },
        "error": {
          "$ref": "#/schemas/Error",
          "description": "Present if the operation failed."
        }
      },
      "additionalProperties": true
    },
    "SoftwareInfo": {
      "type": "object",
      "description": "Identity and metadata for a piece of software.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable display name."
        },
        "version": {
          "type": "string",
          "description": "Software version."
        },
        "description": {
          "type": "string",
          "description": "Brief description."
        },
        "homepage": {
          "type": "string",
          "description": "Documentation URL."
        },
        "repository": {
          "type": "string",
          "description": "Source code URL."
        },
        "maintainer": {
          "type": "string",
          "description": "Author or organization."
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "FormatInfo": {
      "type": "object",
      "description": "Information about a supported binding format.",
      "properties": {
        "token": {
          "type": "string",
          "description": "Format token."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description."
        }
      },
      "required": [
        "token"
      ],
      "additionalProperties": false
    }
  }
