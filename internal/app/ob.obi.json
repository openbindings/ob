  "description": "Portable interfaces, flexible bindings – the ob command-line tool",
  "roles": {
    "openbindings.binding-executor": "https://openbindings.org/spec/interfaces/openbindings.binding-executor/0.1.json",
    "openbindings.context-store": "https://openbindings.org/spec/interfaces/openbindings.context-store/0.1.json",
    "openbindings.software-descriptor": "https://openbindings.org/spec/interfaces/openbindings.software-descriptor/0.1.json"
  },
  "name": "OpenBindings CLI",
  "openbindings": "0.1.0",
  "operations": {
    "assessCompatibility": {
      "description": "Check interface conformance between two interfaces",
      "input": {
        "properties": {
          "candidate": {
            "description": "Candidate interface (locator)",
            "type": "string"
          },
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          },
          "quiet": {
            "description": "Exit code only, no output",
            "type": "boolean"
          },
          "target": {
            "description": "Target interface (locator)",
            "type": "string"
          }
        },
        "required": [
          "target",
          "candidate"
        ],
        "type": "object"
      },
      "tags": [
        "authoring"
      ],
      "x-ob": {}
    },
    "compareInterfaces": {
      "description": "Structural comparison of two OBIs",
      "input": {
        "properties": {
          "baseline": {
            "description": "Baseline OBI (file path, URL, or exec: locator)",
            "type": "string"
          },
          "comparison": {
            "description": "Comparison OBI (omit with --from-sources)",
            "type": "string"
          },
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "from-sources": {
            "description": "Compare against what binding sources produce",
            "type": "boolean"
          },
          "only": {
            "description": "Scope to a specific source key (requires --from-sources)",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          },
          "quiet": {
            "description": "Exit code only, no output",
            "type": "boolean"
          }
        },
        "required": [
          "baseline"
        ],
        "type": "object"
      },
      "tags": [
        "authoring"
      ],
      "x-ob": {}
    },
    "createDelegate": {
      "description": "Add a delegate",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          },
          "url": {
            "description": "Delegate URL (e.g., exec:my-cli, https://api.example.com)",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "object"
      },
      "tags": [
        "delegate"
      ],
      "x-ob": {}
    },
    "createInterface": {
      "description": "Create an OpenBindings interface, optionally from binding source artifacts.",
      "input": {
        "$ref": "#/schemas/CreateInterfaceInput"
      },
      "output": {
        "$ref": "#/schemas/OpenBindingsInterface"
      },
      "satisfies": [
        {
          "role": "openbindings.binding-executor",
          "operation": "createInterface"
        }
      ],
      "tags": [
        "authoring"
      ]
    },
    "createMCPServer": {
      "description": "Create an MCP server from interfaces and/or URLs",
      "input": {
        "properties": {
          "interfaces": {
            "description": "Interface documents to expose as MCP tools",
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "name": {
            "description": "MCP server name",
            "type": "string"
          },
          "urls": {
            "description": "Interface URLs to resolve and expose as MCP tools",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "output": {
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "toolCount": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "tags": [
        "mcp"
      ],
      "x-ob": {}
    },
    "createSource": {
      "description": "Register a source reference on an OBI",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "key": {
            "description": "Explicit source key (default: derived from format and path)",
            "type": "string"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          },
          "resolve": {
            "description": "Resolution mode: location (default) or content",
            "type": "string"
          },
          "source": {
            "description": "Source path or format:path (e.g., openapi.json or usage@2.0.0:./cli.kdl)",
            "type": "string"
          },
          "uri": {
            "description": "Explicit published URI for location mode",
            "type": "string"
          }
        },
        "required": [
          "obi-path",
          "source"
        ],
        "type": "object"
      },
      "tags": [
        "source"
      ],
      "x-ob": {}
    },
    "deleteContext": {
      "description": "Delete a stored context entry.",
      "input": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Context store key."
          }
        },
        "required": [
          "key"
        ],
        "additionalProperties": false
      },
      "satisfies": [
        {
          "role": "openbindings.context-store",
          "operation": "deleteContext"
        }
      ],
      "tags": [
        "context"
      ]
    },
    "deleteDelegate": {
      "description": "Remove a delegate",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          },
          "url": {
            "description": "Delegate URL",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "object"
      },
      "tags": [
        "delegate"
      ],
      "x-ob": {}
    },
    "deleteOperation": {
      "description": "Remove operations and their bindings from an OBI",
      "input": {
        "properties": {
          "force": {
            "description": "Remove managed operations without warning",
            "type": "boolean"
          },
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "key": {
            "description": "Operation keys to remove",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "required": [
          "obi-path",
          "key"
        ],
        "type": "object"
      },
      "tags": [
        "operation"
      ],
      "x-ob": {}
    },
    "deleteSource": {
      "description": "Remove a source reference from an OBI",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "key": {
            "description": "Source key to remove",
            "type": "string"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "required": [
          "obi-path",
          "key"
        ],
        "type": "object"
      },
      "tags": [
        "source"
      ],
      "x-ob": {}
    },
    "executeBinding": {
      "description": "Execute a resolved binding.",
      "input": {
        "$ref": "#/schemas/ExecuteBindingInput"
      },
      "output": {
        "$ref": "#/schemas/ExecuteBindingOutput"
      },
      "satisfies": [
        {
          "role": "openbindings.binding-executor",
          "operation": "executeBinding"
        }
      ],
      "tags": [
        "binding"
      ]
    },
    "executeLocalOperation": {
      "description": "Execute an operation via a binding",
      "input": {
        "properties": {
          "binding": {
            "description": "Binding key to execute (operation is derived from the entry)",
            "type": "string"
          },
          "context": {
            "description": "Named context to apply (credentials, headers, etc.)",
            "type": "string"
          },
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "input": {
            "description": "Operation input as JSON",
            "type": "string"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "operation": {
            "description": "Operation key to execute",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "required": [
          "obi-path"
        ],
        "type": "object"
      },
      "tags": [
        "operation"
      ],
      "x-ob": {}
    },
    "fetchInterface": {
      "description": "Download an OpenBindings interface from a URL or host",
      "input": {
        "properties": {
          "output": {
            "description": "Write output to file (default: derived from host)",
            "type": "string"
          },
          "url-or-host": {
            "description": "Base URL or host (e.g. localhost:8080)",
            "type": "string"
          }
        },
        "required": [
          "url-or-host"
        ],
        "type": "object"
      },
      "tags": [
        "fetch"
      ],
      "x-ob": {}
    },
    "getContext": {
      "description": "Get a stored context entry by key.",
      "idempotent": true,
      "input": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Context store key."
          }
        },
        "required": [
          "key"
        ],
        "additionalProperties": false
      },
      "output": {
        "$ref": "#/schemas/ContextEntry"
      },
      "satisfies": [
        {
          "role": "openbindings.context-store",
          "operation": "getContext"
        }
      ],
      "tags": [
        "context"
      ]
    },
    "getEnvironmentStatus": {
      "description": "Show environment status or OBI sync report",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "obi-path": {
            "description": "OBI file path (shows sync report instead of env status)",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "type": "object"
      },
      "tags": [
        "environment"
      ],
      "x-ob": {}
    },
    "getInfo": {
      "description": "Return identity and metadata about this software.",
      "idempotent": true,
      "output": {
        "$ref": "#/schemas/SoftwareInfo"
      },
      "satisfies": [
        {
          "role": "openbindings.software-descriptor",
          "operation": "getInfo"
        },
        {
          "role": "openbindings.binding-executor",
          "operation": "getInfo"
        }
      ],
      "tags": [
        "info"
      ]
    },
    "getSource": {
      "description": "Show details of a source reference",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "key": {
            "description": "Source key",
            "type": "string"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "required": [
          "obi-path",
          "key"
        ],
        "type": "object"
      },
      "tags": [
        "source"
      ],
      "x-ob": {}
    },
    "initializeEnvironment": {
      "description": "Initialize an OpenBindings environment (.openbindings/)",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "type": "object"
      },
      "tags": [
        "environment"
      ],
      "x-ob": {}
    },
    "listConflicts": {
      "description": "List merge conflicts between local edits and source changes",
      "input": {
        "properties": {
          "format": {
            "description": "Output format: json|yaml|text",
            "type": "string"
          },
          "obi-path": {
            "description": "Path to the OBI file",
            "type": "string"
          },
          "output": {
            "description": "Write output to file",
            "type": "string"
          }
        },
        "required": [
          "obi-path"
        ],
        "type": "object"
      },
      "tags": [
        "authoring"
      ],
      "x-ob": {}
    },
    "listContexts": {
      "description": "List all stored context entries.",
      "idempotent": true,
      "output": {
